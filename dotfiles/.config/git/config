[core]
  editor = nvim
  pager = delta

[commit]
  verbose = true

[interactive]
  diffFilter = delta --color-only

[delta]
  features = catppuccin-mocha
  navigate = true
  line-numbers = true
  true-color = always
  side-by-side = true

[merge]
  conflictStyle = zdiff3

[include]
  path = ~/.config/git/catppuccin.gitconfig
